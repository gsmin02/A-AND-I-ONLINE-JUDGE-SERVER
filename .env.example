# ── Server ──────────────────────────────────────
SERVER_PORT=8080

# ── MongoDB ──────────────────────────────────────
MONGODB_URI=mongodb://judge:judge123@localhost:27017/online_judge?authSource=admin
MONGODB_USER=judge
MONGODB_PASSWORD=judge123
MONGODB_DATABASE=online_judge
MONGODB_PORT=27017

# ── Redis ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Sandbox ───────────────────────────────────────
SANDBOX_TIME_LIMIT_SECONDS=2
SANDBOX_MEMORY_LIMIT_MB=128
SANDBOX_CPU_LIMIT=1.0
SANDBOX_PIDS_LIMIT=50

SANDBOX_IMAGE_PYTHON=judge-sandbox-python:latest
SANDBOX_IMAGE_KOTLIN=judge-sandbox-kotlin:latest
SANDBOX_IMAGE_DART=judge-sandbox-dart:latest
