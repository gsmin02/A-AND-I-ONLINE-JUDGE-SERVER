# ── Server ──────────────────────────────────────
SERVER_PORT=8080

# ── MongoDB ──────────────────────────────────────
MONGODB_URI=mongodb://judge:judge123@localhost:27017/online_judge?authSource=admin
MONGODB_USER=judge
MONGODB_PASSWORD=judge123
MONGODB_DATABASE=online_judge
MONGODB_PORT=27017

# ── Redis ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT Auth ──────────────────────────────────────
JUDGE_JWT_AUTH_ENABLED=true
JUDGE_JWT_AUTH_SIGNING_KEY=change-me-dev-signing-key
JUDGE_JWT_AUTH_REQUIRED_ROLE=USER
JUDGE_JWT_AUTH_ALLOW_WITHOUT_ROLE_CLAIM=true

# ── Rate Limit ───────────────────────────────────
JUDGE_RATE_LIMIT_ENABLED=true
JUDGE_RATE_LIMIT_SUBMIT_REQUESTS=30
JUDGE_RATE_LIMIT_WINDOW_SECONDS=60

# ── Worker ───────────────────────────────────────
JUDGE_WORKER_MAX_CONCURRENCY=2

# ── Problem Events (SQS/SNS) ─────────────────────
JUDGE_PROBLEM_EVENTS_ENABLED=false
REPORTS_TESTCASES_EVENTS_QUEUE_URL=
JUDGE_PROBLEM_EVENTS_WAIT_TIME_SECONDS=20
JUDGE_PROBLEM_EVENTS_MAX_MESSAGES=10

# ── User Events (SQS) ─────────────────────────────
JUDGE_USER_EVENTS_ENABLED=false
JUDGE_USER_EVENTS_QUEUE_URL=
JUDGE_USER_EVENTS_WAIT_TIME_SECONDS=20
JUDGE_USER_EVENTS_MAX_MESSAGES=10

# ── Sandbox ───────────────────────────────────────
SANDBOX_TIME_LIMIT_SECONDS=2
SANDBOX_MEMORY_LIMIT_MB=256
SANDBOX_CPU_LIMIT=1.0
SANDBOX_PIDS_LIMIT=50

SANDBOX_IMAGE_PYTHON=judge-sandbox-python:latest
SANDBOX_IMAGE_KOTLIN=judge-sandbox-kotlin:latest
SANDBOX_IMAGE_DART=judge-sandbox-dart:latest
